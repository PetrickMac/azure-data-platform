    target_fqdns     = ["*.windowsupdate.microsoft.com", "*.update.microsoft.com"]
    protocol {
      port = "443"
      type = "Https"
    }
  }

  rule {
    name             = "Allow-Azure-Services"
    source_addresses = ["10.0.0.0/8"]
    target_fqdns     = ["*.azure.com", "*.microsoft.com", "*.core.windows.net"]
    protocol {
      port = "443"
      type = "Https"
    }
  }
}
